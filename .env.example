# ── GitHub ─────────────────────────────────────────────────────────────────
# Optional: increases rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=ghp_...

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: claude | gemini | openai | ollama
LLM_PROVIDER=claude

# ── Claude (Anthropic) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional: default is claude-opus-4-6
# ANTHROPIC_MODEL=claude-opus-4-6

# ── Gemini (Google) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Optional: default is gemini-2.0-flash
# GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI / Codex ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional: default is gpt-4o
# OPENAI_MODEL=gpt-4o

# ── Ollama (local, no cost) ──────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Radar Config ────────────────────────────────────────────────────────────
# Optional: default is the directory where repo-radar is installed
# RADAR_HOME=/path/to/radar
RADAR_SKIP_FORKS=false
RADAR_SKIP_ARCHIVED=true
